rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Profiles
    match /users/{uid} {
      // Reads are allowed so username -> email login lookup works and admins can list.
      allow read: if true;

      // A user may create only their own profile.
      allow create: if isSelf(uid);

      // A user may update their own profile but NOT escalate role/plan/status.
      allow update: if isAdmin()
        || (isSelf(uid)
            && request.resource.data.role == resource.data.role
            && request.resource.data.plan == resource.data.plan
            && request.resource.data.status == resource.data.status);

      allow delete: if isAdmin();
    }

    // Username registry (uniqueness)
    match /usernames/{handle} {
      allow read: if true;                       // availability + login resolution
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
